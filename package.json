{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "cf:dev": "wrangler pages dev dist --d1=BATI_DB",
    "cf:deploy": "npm run build && npx wrangler pages deploy dist",
    "d1:migrate:local": "wrangler d1 migrations apply BATI_DB --local",
    "d1:migrate:remote": "wrangler d1 migrations apply BATI_DB --remote"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.40.0"
  },
  "dependencies": {
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  }
}